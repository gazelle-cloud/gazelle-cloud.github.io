---
import Base from './Base.astro';

interface Props {
  title: string;
  fullTitle?: boolean;
  description?: string;
  page: string;    // path to the .page.js file in public/, e.g. "/knowledge-graph.page.js"
  noindex?: boolean;
}

const { title, fullTitle = false, description, page, noindex = false } = Astro.props;
---
<Base title={title} fullTitle={fullTitle} description={description} noindex={noindex}>
  <link rel="stylesheet" href="/shell.css" />
  <script is:inline type="importmap">{ "imports": {
    "react": "https://esm.sh/react",
    "react/jsx-runtime": "https://esm.sh/react/jsx-runtime",
    "react-dom": "https://esm.sh/react-dom",
    "react-dom/client": "https://esm.sh/react-dom/client"
  }}</script>

  <slot />

  <script is:inline type="module" src={page}></script>
</Base>
