---
import GraphPage from '../../layouts/GraphPage.astro';
import data from '../../../public/landing-zone.json';
---
<GraphPage title="Landing Zone" graph="/landing-zone-graph.jsx">
  <div class="sr-only">
    <h1>Landing Zone Design Areas</h1>
    <p>Each spoke represents a design area — a domain of concern that shapes how the landing zone is built and governed. Guardrails are the concrete policy and configuration decisions that enforce each area.</p>
    <ul>
      {data.nodes.map((n: any) => (
        <li>
          <a href={`/landing-zone/${n.id}/`}>{n.label || n.id}</a>
        </li>
      ))}
    </ul>
  </div>
</GraphPage>
