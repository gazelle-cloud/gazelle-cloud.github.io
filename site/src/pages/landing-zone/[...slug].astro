---
import Base from '../../layouts/Base.astro';
import data from '../../../public/landing-zone.json';

export function getStaticPaths() {
  return data.nodes.map((n: any) => ({
    params: { slug: n.id.replace(/\/+$/, '') },
    props: { node: n },
  }));
}

const { node } = Astro.props as { node: any };
const name = node.id;
---
<Base title={name}>
  <script is:inline define:vars={{ name }}>
    window.location.replace('/landing-zone/#' + name);
  </script>

  <div class="sr-only">
    <h1>{name}</h1>
    <p>Type: {node.type}</p>

    {node.description && (
      <>
        <h2>Description</h2>
        <p>{node.description}</p>
      </>
    )}

    <p><a href="/landing-zone/">← Back to landing zone</a></p>
  </div>
</Base>
