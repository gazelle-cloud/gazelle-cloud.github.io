---
import GraphPage from '../../layouts/GraphPage.astro';
import data from '../../../public/bigbang.json';
---
<GraphPage title="Gazelle — How the platform comes alive" fullTitle description="One workflow that bootstraps the full Azure landing zone platform from scratch — every GitHub workflow, Bicep file, and module visualised." page="/bigbang.page.js">
  <div class="sr-only">
    <h1>BigBang — Platform Deployment Workflows</h1>
    <p>How each platform capability is deployed end-to-end — from GitHub workflows through main Bicep files to individual modules.</p>
    <ul>
      {data.nodes.map((n: any) => (
        <li>
          <a href={`/bigbang/${n.id}/`}>{n.label || n.id}</a>
        </li>
      ))}
    </ul>
  </div>
</GraphPage>
