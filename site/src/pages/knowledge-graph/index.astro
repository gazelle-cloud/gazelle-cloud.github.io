---
import GraphPage from '../../layouts/GraphPage.astro';
import graph from '../../../public/knowledge-graph.json';

const rules = graph.nodes.filter((n: any) => n.type === 'rule');
const decisions = graph.nodes.filter((n: any) => n.type === 'decision');
---
<GraphPage title="Knowledge Graph" description="Platform design rules and decisions that shape the Azure landing zone — how deny-by-default, self-service, and zero-cost-on-idle connect." graph="/knowledge-graph-graph.jsx">
  <div class="sr-only">
    <h1>Platform Design Knowledge Graph</h1>

    <h2>Rules</h2>
    <ul>
      {rules.map((r: any) => (
        <li>
          <a href={`/knowledge-graph/${r.id}/`}>{r.id}</a>
          {r.intent && <span> — {r.intent}</span>}
        </li>
      ))}
    </ul>

    <h2>Decisions</h2>
    <ul>
      {decisions.map((d: any) => (
        <li>
          <a href={`/knowledge-graph/${d.id}/`}>{d.id}</a>
          {d.decision && <span> — {d.decision}</span>}
        </li>
      ))}
    </ul>
  </div>
</GraphPage>
