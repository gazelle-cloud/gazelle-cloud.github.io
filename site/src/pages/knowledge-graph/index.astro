---
import GraphPage from '../../layouts/GraphPage.astro';

import { DATA_REPO, BASE_PATH } from '../../data';

async function fetchCategory(category: string): Promise<any[]> {
  const res = await fetch(`https://api.github.com/repos/${DATA_REPO}/contents/${BASE_PATH}/${category}`);
  const listing: any[] = await res.json();
  if (!Array.isArray(listing)) return [];
  const type = category === 'guiding-principles' ? 'guiding-principle' : category.replace(/s$/, '');
  return Promise.all(
    listing
      .filter((f: any) => f.type === 'file' && f.name.endsWith('.json'))
      .map((f: any) => fetch(f.download_url).then(r => r.json()).then((obj: any) => ({ ...obj, type })))
  );
}

const [principles, decisions] = await Promise.all([
  fetchCategory('guiding-principles'),
  fetchCategory('decisions'),
]);
---
<GraphPage title="Gazelle — The decisions behind the platform" fullTitle description="Platform design rules and decisions that shape the Azure landing zone — how deny-by-default, self-service, and zero-cost-on-idle connect." page="/knowledge-graph.page.js">
  <div class="sr-only">
    <h1>Platform Design Knowledge Graph</h1>

    <h2>Guiding Principles</h2>
    <ul>
      {principles.map((r: any) => (
        <li>
          <a href={`/knowledge-graph/${r.id}/`}>{r.id}</a>
          {r.intent && <span> — {r.intent}</span>}
        </li>
      ))}
    </ul>

    <h2>Decisions</h2>
    <ul>
      {decisions.map((d: any) => (
        <li>
          <a href={`/knowledge-graph/${d.id}/`}>{d.id}</a>
          {d.decision && <span> — {d.decision}</span>}
        </li>
      ))}
    </ul>
  </div>
</GraphPage>
