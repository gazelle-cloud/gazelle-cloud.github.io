---
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const DATA_REPO = 'gazelle-cloud/data';
  const BASE_PATH = 'knowledge-graph';

  async function fetchCategory(category: string, type: string): Promise<any[]> {
    const res = await fetch(`https://api.github.com/repos/${DATA_REPO}/contents/${BASE_PATH}/${category}`);
    const listing: any[] = await res.json();
    if (!Array.isArray(listing)) return [];
    return Promise.all(
      listing
        .filter((f: any) => f.type === 'file' && f.name.endsWith('.json'))
        .map((f: any) => fetch(f.download_url).then(r => r.json()).then((obj: any) => ({ ...obj, type })))
    );
  }

  const [principles, decisions] = await Promise.all([
    fetchCategory('guiding-principles', 'guiding-principle'),
    fetchCategory('decisions', 'decision'),
  ]);
  const nodes = [...principles, ...decisions];
  return nodes.map((n: any) => ({
    params: { slug: n.id },
    props:  { node: n },
  }));
}

const { node } = Astro.props as { node: any };
const name  = node.id;
const label = node.label || name.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
const desc  = (node.intent || node.decision || node.why || '').slice(0, 155);
---
<Base title={label} description={desc || undefined}>
  <script is:inline define:vars={{ name }}>
    window.location.replace('/knowledge-graph/#' + name);
  </script>

  <div class="sr-only">
    <h1>{name}</h1>
    <p>Type: {node.type}</p>

    {node.intent && (
      <>
        <h2>Intent</h2>
        <p>{node.intent}</p>
      </>
    )}

    {node.decision && (
      <>
        <h2>Decision</h2>
        <p>{node.decision}</p>
      </>
    )}

    {node.why && (
      <>
        <h2>Why</h2>
        <p>{node.why}</p>
      </>
    )}

    {node.violations?.length > 0 && (
      <>
        <h2>Violations</h2>
        <ul>
          {node.violations.map((v: string) => (
            <li>{v}</li>
          ))}
        </ul>
      </>
    )}

    {node.decisions?.length > 0 && (
      <>
        <h2>Decisions</h2>
        <ul>
          {node.decisions.map((id: string) => (
            <li><a href={`/knowledge-graph/${id}/`}>{id}</a></li>
          ))}
        </ul>
      </>
    )}

    {node.links?.length > 0 && (
      <>
        <h2>Links</h2>
        <ul>
          {node.links.map((l: any) => (
            <li>
              <a href={`/knowledge-graph/${l.id}/`}>{l.id}</a>
              {l.note && <span> — {l.note}</span>}
            </li>
          ))}
        </ul>
      </>
    )}

    <p><a href="/knowledge-graph/">← Back to knowledge graph</a></p>
  </div>
</Base>
