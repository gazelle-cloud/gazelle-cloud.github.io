---
import Base from '../../layouts/Base.astro';
import graph from '../../../public/knowledge-graph.json';

export function getStaticPaths() {
  return graph.nodes.map((n: any) => ({
    params: { slug: n.id },
    props: { node: n },
  }));
}

const { node } = Astro.props as { node: any };
const name = node.id;
const label = node.label || name.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
const desc = (node.intent || node.decision || node.why || '').slice(0, 155);
---
<Base title={label} description={desc || undefined}>
  <script is:inline define:vars={{ name }}>
    window.location.replace('/knowledge-graph/#' + name);
  </script>

  <div class="sr-only">
    <h1>{name}</h1>
    <p>Type: {node.type}</p>

    {node.intent && (
      <>
        <h2>Intent</h2>
        <p>{node.intent}</p>
      </>
    )}

    {node.decision && (
      <>
        <h2>Decision</h2>
        <p>{node.decision}</p>
      </>
    )}

    {node.why && (
      <>
        <h2>Why</h2>
        <p>{node.why}</p>
      </>
    )}

    {node.violations?.length > 0 && (
      <>
        <h2>Violations</h2>
        <ul>
          {node.violations.map((v: string) => (
            <li>{v}</li>
          ))}
        </ul>
      </>
    )}

    {node.links?.length > 0 && (
      <>
        <h2>Links</h2>
        <ul>
          {node.links.map((l: any) => (
            <li>
              <a href={`/knowledge-graph/${l.id}/`}>{l.id}</a>
              {l.note && <span> — {l.note}</span>}
            </li>
          ))}
        </ul>
      </>
    )}

    <p><a href="/knowledge-graph/">← Back to all decisions</a></p>
  </div>
</Base>
