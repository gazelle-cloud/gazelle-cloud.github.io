---
import Base from '../layouts/Base.astro';
---
<Base title="Gazelle — Landing zones at the speed of code" fullTitle description="An interactive map of Azure landing zone — design decisions, platform operations, and deployment workflows visualised.">
  <link rel="stylesheet" href="/shell.css" />

  <!-- ── top bar (same structure as graph pages) ──────────────────────── -->
  <header id="top-bar">
    <button id="menu-btn" aria-label="Toggle menu">&#9776;</button>
    <div class="top-bar-panel">
      <nav class="top-bar-nav">
        <a class="nav-link nav-active" href="/">Home</a>
        <span class="nav-sep">|</span>
        <a class="nav-link" href="/knowledge-graph/">Knowledge Graph</a>
        <span class="nav-sep">|</span>
        <a class="nav-link" href="/operations/">Operations</a>
        <span class="nav-sep">|</span>
        <a class="nav-link" href="/bigbang/">BigBang</a>
      </nav>
      <div class="top-bar-right">
        <button class="theme-toggle" id="theme-toggle" aria-label="Switch theme"></button>
        <a href="https://github.com/gazelle-cloud/Azure-landing-zones" target="_blank" rel="noopener noreferrer" class="gh-link" aria-label="GitHub repository" title="GitHub repository">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </div>
  </header>

  <script is:inline>
    (function() {
      /* ── theme toggle ────────────────────────────────────────────────── */
      const btn = document.getElementById('theme-toggle');
      const saved = localStorage.getItem('theme');
      const initial = saved ? saved : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      document.documentElement.dataset.theme = initial === 'light' ? 'light' : '';
      btn.textContent = initial === 'dark' ? '\u2600' : '\u263E';
      btn.addEventListener('click', () => {
        const current = document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next === 'light' ? 'light' : '';
        localStorage.setItem('theme', next);
        btn.textContent = next === 'dark' ? '\u2600' : '\u263E';
      });

      /* ── hamburger menu toggle ───────────────────────────────────────── */
      var menuBtn = document.getElementById('menu-btn');
      var topBar = document.getElementById('top-bar');
      menuBtn.addEventListener('click', function() {
        var open = topBar.classList.toggle('menu-open');
        menuBtn.innerHTML = open ? '&#10005;' : '&#9776;';
      });
      document.addEventListener('pointerdown', function(e) {
        if (topBar.classList.contains('menu-open') && !topBar.contains(e.target)) {
          topBar.classList.remove('menu-open');
          menuBtn.innerHTML = '&#9776;';
        }
      });
    })();
  </script>

  <!-- ── page content ─────────────────────────────────────────────────── -->
  <main class="landing">
    <section class="hero">
      <h1>Gazelle <span class="accent">Cloud</span></h1>
      <p class="tagline tagline-primary">Azure landing zones at the speed of code</p>
    </section>

    <div class="how-it-works">
      <div class="hiw-big-label">The flow</div>
      <div class="hiw-big-vline"></div>
      <div class="hiw-big-wrap">
        <canvas id="mini-graph"></canvas>
      </div>
    </div>


    <section class="cards">
      <a href="/knowledge-graph/" class="card card-gold">
        <h2>Knowledge Graph <span class="card-arrow">&rarr;</span></h2>
        <p>Captures the reasoning behind every platform decision.</p>
      </a>
      <a href="/operations/" class="card card-green">
        <h2>Operations <span class="card-arrow">&rarr;</span></h2>
        <p>How AI operates the platform — decisions to respect, files to touch, sequence to follow.</p>
      </a>
      <a href="/bigbang/" class="card card-blue">
        <h2>BigBang <span class="card-arrow">&rarr;</span></h2>
        <p>Workflows that bring the platform from nothing to life.</p>
      </a>
    </section>

  </main>

  <script is:inline>
    (function () {
      const canvas = document.getElementById('mini-graph');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');

      // wx/wy: incommensurable frequencies per dot — both axes move simultaneously
      const NODES = [
        { name: 'Join',    color: '#f0a500', href: '/knowledge-graph/landing-zone-application-profile/', wx: 0.19, wy: 0.33, px: 0.0,  py: 0.0  },
        { name: 'Request', color: '#3dba7f',                                                              wx: 0.27, wy: 0.18, px: 2.09, py: 1.05 },
        { name: 'Deploy',  color: '#4e8ef7',                                                              wx: 0.23, wy: 0.38, px: 4.19, py: 2.09 },
      ];
      const R = 8;
      let w = 0, h = 0, paused = false;

      function resize() {
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        const rect = canvas.parentElement.getBoundingClientRect();
        w = rect.width; h = rect.height;
        canvas.width = w * dpr; canvas.height = h * dpr;
        canvas.style.width = w + 'px'; canvas.style.height = h + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      function tick() {
        const t      = performance.now() * 0.001;
        const zoneW  = w / 3;
        const yMin   = R + 6;
        const yMax   = h - R - 24;  // gap(6) + line(14) + margin(4)
        const cy     = (yMin + yMax) / 2;
        const Ay     = (yMax - yMin) / 2 * 0.9;
        NODES.forEach((n, i) => {
          const zcx = zoneW * (i * 2 + 1) * 0.5;
          const Ax  = Math.max(0, zoneW * 0.5 - R - (n.halfW ?? 40) - 8);
          n.x = zcx + Ax * Math.cos(n.wx * t + n.px);
          n.y = cy  + Ay * Math.sin(n.wy * t + n.py);
        });
      }

      function draw() {
        ctx.clearRect(0, 0, w, h);
        const dark = document.documentElement.dataset.theme !== 'light';
        const labelColor = dark ? 'rgba(155,175,215,0.55)' : 'rgba(26,27,38,0.45)';
        ctx.textAlign = 'center'; ctx.textBaseline = 'top';
        ctx.font = '600 11px system-ui,-apple-system,sans-serif';
        ctx.letterSpacing = '0.09em';
        for (const n of NODES) {
          ctx.beginPath(); ctx.arc(n.x, n.y, R, 0, Math.PI * 2);
          ctx.fillStyle = n.color; ctx.fill();
          ctx.fillStyle = labelColor;
          const text = n.name.toUpperCase();
          n.halfW = ctx.measureText(text).width / 2;
          ctx.fillText(text, n.x, n.y + R + 6);
        }
      }

      function hitNode(ex, ey) {
        const rect = canvas.getBoundingClientRect();
        const x = ex - rect.left, y = ey - rect.top;
        for (let i = NODES.length - 1; i >= 0; i--) {
          const n = NODES[i];
          const dx = x - n.x, dy = y - n.y;
          if (dx * dx + dy * dy <= (R + 6) * (R + 6)) return n;
        }
        return null;
      }

      canvas.addEventListener('mousemove', e => {
        canvas.style.cursor = hitNode(e.clientX, e.clientY) ? 'pointer' : 'default';
      });
      canvas.addEventListener('mouseleave', () => { canvas.style.cursor = 'default'; });
      canvas.addEventListener('click', e => {
        const n = hitNode(e.clientX, e.clientY);
        if (n && n.href) window.location.href = n.href;
      });

      function loop() {
        if (paused) return;
        tick(); draw();
        requestAnimationFrame(loop);
      }

      window.addEventListener('resize', resize);
      document.addEventListener('visibilitychange', () => {
        paused = document.hidden;
        if (!paused) requestAnimationFrame(loop);
      });
      new MutationObserver(draw)
        .observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

      requestAnimationFrame(() => { resize(); loop(); });
    })();
  </script>
</Base>

<style>
  /* override shell.css: landing page scrolls normally */
  :global(html), :global(body) { overflow: auto !important; height: auto !important; }
  :global(.top-bar-right) { width: auto !important; }
  :global(#menu-btn) { display: none; }

  .landing {
    max-width: 900px;
    margin: 0 auto;
    padding: 24px;
  }

  /* ── hero ─────────────────────────────────────────────────────────────── */
  .hero {
    text-align: center;
    padding: 64px 0 48px;
  }
  .hero-label {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #f0a500;
    margin-bottom: 16px;
  }
  .hero h1 {
    font-size: 3rem;
    font-weight: 500;
    margin: 0 0 12px;
    color: var(--text-primary, #d4daf0);
  }
  .accent { color: #f0a500; }
  .tagline {
    font-size: 1.05rem;
    color: rgba(155, 175, 215, 0.6);
    margin: 0 0 24px;
  }
  .tagline-primary {
    font-size: 1.4rem;
    font-weight: 400;
    color: rgba(212, 218, 240, 0.9);
    margin-bottom: 8px;
  }
  .sub-hero {
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.6;
    color: rgba(212, 218, 240, 0.85);
  }

  /* ── cards ────────────────────────────────────────────────────────────── */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    padding-bottom: 48px;
  }
  .card {
    display: block;
    text-decoration: none;
    color: #d4daf0;
    background: rgba(155, 175, 215, 0.06);
    border: 1px solid rgba(155, 175, 215, 0.12);
    border-radius: 10px;
    padding: 24px;
    transition: border-color 0.15s, background 0.15s;
  }
  .card:hover { background: rgba(155, 175, 215, 0.10); }
  .card h2 {
    font-size: 1.2rem;
    font-weight: 500;
    margin: 0 0 8px;
  }
  .card-arrow {
    opacity: 0.4;
    transition: opacity 0.15s, transform 0.15s;
    display: inline-block;
  }
  .card:hover .card-arrow {
    opacity: 1;
    transform: translateX(3px);
  }
  .card p {
    font-size: 1rem;
    line-height: 1.55;
    margin: 0;
    color: rgba(155, 175, 215, 0.75);
  }

  /* card accent borders */
  .card-gold   { border-top: 3px solid #f0a500; }
  .card-green  { border-top: 3px solid #3dba7f; }
  .card-blue   { border-top: 3px solid #4e8ef7; }
  .card-gold:hover   { border-color: #f0a500; }
  .card-green:hover  { border-color: #3dba7f; }
  .card-blue:hover   { border-color: #4e8ef7; }

  .link-box {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 12px;
    padding: 8px 12px;
    background: rgba(155, 175, 215, 0.08);
    border: 1px solid rgba(155, 175, 215, 0.15);
    border-radius: 6px;
    font-size: 0.82rem;
  }
  .link-box-url {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: #f0a500;
    text-decoration: none;
  }
  .link-box-url:hover { text-decoration: underline; }
  .link-box-copy {
    flex-shrink: 0;
    padding: 4px 12px;
    border: 1px solid rgba(155, 175, 215, 0.2);
    border-radius: 4px;
    background: rgba(155, 175, 215, 0.1);
    color: #d4daf0;
    font-size: 0.78rem;
    cursor: pointer;
    transition: background 0.15s;
  }
  .link-box-copy:hover { background: rgba(155, 175, 215, 0.2); }

  /* ── footer ──────────────────────────────────────────────────────────── */
  .footer {
    text-align: center;
    padding: 24px;
    font-size: 0.8rem;
    color: rgba(155, 175, 215, 0.4);
    border-top: 1px solid rgba(155, 175, 215, 0.08);
  }
  .footer p { margin: 0; }

  /* ── light theme ─────────────────────────────────────────────────────── */
  :global([data-theme="light"]) .hero h1 { color: #1a1b26; }
  :global([data-theme="light"]) .tagline { color: rgba(26,27,38,0.45); }
  :global([data-theme="light"]) .tagline-primary { color: rgba(26,27,38,0.8); }
  :global([data-theme="light"]) .card {
    color: #1a1b26;
    background: rgba(0,0,0,0.02);
    border-left-color: rgba(0,0,0,0.08);
    border-right-color: rgba(0,0,0,0.08);
    border-bottom-color: rgba(0,0,0,0.08);
  }
  :global([data-theme="light"]) .card:hover { background: rgba(0,0,0,0.04); }
  :global([data-theme="light"]) .card p { color: rgba(26,27,38,0.55); }
  :global([data-theme="light"]) .card-gold:hover   { border-color: #f0a500; }
  :global([data-theme="light"]) .card-green:hover  { border-color: #3dba7f; }
  :global([data-theme="light"]) .card-blue:hover   { border-color: #4e8ef7; }
  :global([data-theme="light"]) .link-box {
    background: rgba(0, 0, 0, 0.04);
    border-color: rgba(0, 0, 0, 0.1);
  }
  :global([data-theme="light"]) .link-box-url { color: #c88d00; }
  :global([data-theme="light"]) .link-box-copy {
    color: #1a1b26;
    border-color: rgba(0, 0, 0, 0.15);
    background: rgba(0, 0, 0, 0.05);
  }
  :global([data-theme="light"]) .link-box-copy:hover { background: rgba(0, 0, 0, 0.1); }

  /* ── how it works (canvas) ───────────────────────────────────────────── */
  .how-it-works {
    display: flex;
    align-items: stretch;
    border: 1px solid rgba(155, 175, 215, 0.12);
    border-radius: 10px;
    margin-bottom: 20px;
    background: rgba(155, 175, 215, 0.06);
    overflow: hidden;
  }
  .hiw-big-label {
    padding: 0 24px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: rgba(155, 175, 215, 0.4);
    white-space: nowrap;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }
  .hiw-big-vline {
    width: 1px;
    background: rgba(155, 175, 215, 0.12);
    flex-shrink: 0;
  }
  .hiw-big-wrap {
    flex: 1;
    height: 120px;
  }
  #mini-graph { display: block; }

  :global([data-theme="light"]) .hiw-big-label { color: rgba(26,27,38,0.3); }
  :global([data-theme="light"]) .hiw-big-vline { background: rgba(0,0,0,0.1); }

  /* ── responsive ──────────────────────────────────────────────────────── */
  @media (max-width: 700px) {
    .hero h1 { font-size: 2rem; }
    .hero { padding: 40px 0 32px; }
    .cards { grid-template-columns: 1fr; }
  }
</style>
