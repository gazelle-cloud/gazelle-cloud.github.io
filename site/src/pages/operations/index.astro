---
import GraphPage from '../../layouts/GraphPage.astro';
import data from '../../../public/operations.json';
---
<GraphPage title="Operations" description="Standardised operations that manage the Azure landing zone platform — the files each one touches and the design decisions that shape it." graph="/operations-graph.jsx">
  <div class="sr-only">
    <h1>Platform Operations</h1>
    <p>Standardized operations that manage the Gazelle Cloud platform — the files each one touches and the design decisions that shape it.</p>
    <ul>
      {data.nodes.map((n: any) => (
        <li>
          <a href={`/operations/${n.id}/`}>{n.label || n.id}</a>
        </li>
      ))}
    </ul>
  </div>
</GraphPage>
