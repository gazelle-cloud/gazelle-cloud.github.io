          "note": "Diagnostic settings are platform-defined — the platform controls what ingests into this workspace"
        },
        {
          "@id": "single-region",
          "note": "Log Analytics workspace is regional."
        }
      ]
    },
    {
      "@id": "landing-zone-repo",
      "@type": "Decision",
      "decision": "Each application gets a GitHub repository that serves as the control and deployment plane for all its landing zones",
      "why": "Without the repo, platform has no place to write application configuration details.",
      "violations": [
        "Bring-your-own-Repo for landing zone creation"
      ],
      "files": [],
      "links": [
