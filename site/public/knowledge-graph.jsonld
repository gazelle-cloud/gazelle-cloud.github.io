    {
      "@id": "landing-zone-resource-group",
      "@type": "Decision",
      "decision": "Platform-managed landing zone resources live in a single resource group, protected by an Azure Deployment Stack.",
      "why": "A shared resource group blends platform and application resources. No clean boundary exists for teardown, RBAC, or incident management when both share the same scope.",
      "violations": [
        "Provisioning a resource outside the main.bicep landing zone template"
      ],
      "files": [
