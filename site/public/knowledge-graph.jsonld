    {
      "@id": "create-landing-zone",
      "@type": "Operation",
      "intent": "A new isolated Azure environment is provisioned under the application team's billing scope, with guardrails pre-wired and ready for workload deployment.",
      "workflow": "requestNew-Landing-Zone",
