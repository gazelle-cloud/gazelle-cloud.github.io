        },
        {
          "@id": "declarative-resource-lifecycle",
          "note": "Resource group is the Deployment Stack scope — deleteAll tears down every platform-managed resource in one operation."
        },
        {
          "@id": "landing-zone-monitoring",
          "note": "Log Analytics workspace lives inside this resource group and managed by Azure Deployment Stack."
        },
        {
          "@id": "landing-zone-vnet",
          "note": "VNet is provisioned inside this resource group and managed by platform Deployment Stack"
        },
        {
          "@id": "landing-zone-automation",
          "note": "Container Apps environment and jobs are provisioned inside this resource group and managed by Azure Deployment Stack"
        }
      ]
    },
    {
      "@id": "landing-zone-tags",
      "@type": "Decision",
      "decision": "The platform configures tags to identify application engineers and owners.",
      "why": "Manually applied tags drift within weeks — when an incident fires, the email points to someone who left the team, and the alert goes unanswered.",
      "violations": [
        "Introducing a tag that does not apply to all application landing zones"
      ],
      "files": [
        "landing-zones/bicep/modules/azurePolicy.bicep",
