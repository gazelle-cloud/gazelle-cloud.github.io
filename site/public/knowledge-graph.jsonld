    {
      "@id": "self-service-policy-exemptions",
      "@type": "Decision",
      "decision": "Application teams can request a temporary or long-lived exemption from a specific Azure Policy assignment via a self-service workflow.",
      "why": "The hard deny is only sustainable if teams can unblock themselves — without that, deny-by-default erodes under operational pressure.",
      "violations": [
        "Exemption description that does not name the reason for the exemption."
      ],
      "files": [
        "landing-zones/bicep/modules/base/policyExemption.bicep",
